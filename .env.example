# Endpoint de WPGraphQL de tu WordPress.
# Local (Local by Flywheel): suele ser https://anima-headless.local/graphql
# Producción: https://TU-DOMINIO-WP/graphql
WORDPRESS_API_URL=https://anima-headless.local/graphql

# Public canonical site URL. Used for metadata, Open Graph, JSON-LD, and sitemap.
NEXT_PUBLIC_SITE_URL=https://www.animavillage.com

# === Doppler Newsletter ===
# Suscripciones del form del footer. La key vive sólo en el server
# (Route Handler en /api/subscribe). Configúrala en Vercel también.
DOPPLER_API_KEY=
DOPPLER_ACCOUNT=gmajul@animavillage.com
DOPPLER_LIST_ID=29207920

# === Modo Coming Soon ===
# COMING_SOON=true → todo el público ve /coming-soon (la URL no cambia).
# Para ver las páginas internas: visita cualquier URL con ?preview=<PREVIEW_TOKEN>
# (setea cookie de bypass por 30 días). ?preview=off la borra.
# En local déjalo apagado; en Vercel ponlo en true mientras el sitio no sea público.
COMING_SOON=false
PREVIEW_TOKEN=
